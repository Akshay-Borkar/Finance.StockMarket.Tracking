{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "",
    "Issuer": "FinanceStockMarket.Api",
    "Audience": "FinanceStockMarketUser",
    "DurationInMinutes": 15
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "portfolio-route": {
        "ClusterId": "portfolio",
        "Match": { "Path": "/api/portfolio/{**catch-all}" }
      },
      "stocksector-route": {
        "ClusterId": "portfolio",
        "Match": { "Path": "/api/stocksector/{**catch-all}" }
      },
      "alerts-route": {
        "ClusterId": "monolith",
        "Match": { "Path": "/api/alerts/{**catch-all}" }
      },
      "sentiment-route": {
        "ClusterId": "sentiment",
        "Match": { "Path": "/api/sentiment/{**catch-all}" }
      },
      "hubs-route": {
        "ClusterId": "monolith",
        "Match": { "Path": "/hubs/{**catch-all}" }
      },
      "hangfire-route": {
        "ClusterId": "marketdata",
        "Match": { "Path": "/hangfire/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity-d1": {
            "Address": "http://identity-svc:8080"
          }
        }
      },
      "sentiment": {
        "Destinations": {
          "sentiment-d1": {
            "Address": "http://sentiment-svc:8080"
          }
        }
      },
      "marketdata": {
        "Destinations": {
          "marketdata-d1": {
            "Address": "http://marketdata-svc:8080"
          }
        }
      },
      "portfolio": {
        "Destinations": {
          "portfolio-d1": {
            "Address": "http://portfolio-svc:8080"
          }
        }
      },
      "monolith": {
        "Destinations": {
          "monolith-d1": {
            "Address": "http://monolith:8080"
          }
        }
      }
    }
  }
}
